{
  "name": "camelagi",
  "version": "0.5.39",
  "description": "Personal AI agent powered by Claude Agent SDK — manage everything from Telegram",
  "type": "module",
  "bin": {
    "camelagi": "./camelagi.mjs",
    "camel": "./camelagi.mjs"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js serve",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "bundle:gateway": "node esbuild.gateway.mjs",
    "build:all": "npm run build && npm run bundle:gateway",
    "postinstall": "echo '\n  \\033[36mCamelAGI\\033[0m installed!\\n\\n  Get started:\\n    camel setup    # First-time setup\\n    camel serve    # Start server\\n    camel chat     # Terminal UI\\n'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.79",
    "@anthropic-ai/sdk": "^0.x",
    "@clack/prompts": "^1.1.0",
    "@mariozechner/pi-tui": "^0.57.1",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "discord.js": "^14.25.1",
    "dotenv": "^16.x",
    "express": "^4.x",
    "grammy": "^1.x",
    "openai": "^6.27.0",
    "ora": "^9.3.0",
    "sharp": "^0.34.5",
    "ws": "^8.x",
    "yaml": "^2.x",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.x",
    "@types/node": "^22.x",
    "@types/ws": "^8.x",
    "esbuild": "^0.27.4",
    "tsx": "^4.x",
    "typescript": "^5.7.x",
    "vitest": "^3.x"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inawafalm/CamelAGI.git"
  },
  "homepage": "https://github.com/inawafalm/CamelAGI#readme",
  "bugs": {
    "url": "https://github.com/inawafalm/CamelAGI/issues"
  },
  "files": [
    "dist/",
    "camelagi.mjs",
    "config.example.yaml",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": "Nawaf Almutairi",
  "keywords": [
    "ai",
    "agent",
    "claude",
    "anthropic",
    "telegram",
    "assistant",
    "claude-agent-sdk",
    "bot"
  ],
  "engines": {
    "node": ">=20"
  }
}
